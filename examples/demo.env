# DvP demo world — reference values for the three flagship flow scripts.
#
# These ids/principals are from a reference demo deployment on a non-production dev cluster;
# they document the exact call sequences the flows exercise. To run the flows against
# your own cluster, deploy the canisters (see smart-contracts/*/thebes.toml.example), then
# override CASH/SHARES/LAND/CORE/XCHG/LISTING and the actor principals below.
#
# `TD` = path to the thebes-deploy binary; `MAN` = your matching manifest; `NET` = network flag.
export TD="${TD:-thebes-deploy}"
export MAN="${MAN:-thebes.toml}"
export NET="${NET:---network local}"

# ── Backend canisters (cid + principal) ──
export CASH=113038164393856      ; export CASH_P=g5mfi-tyaab-tm5p5-cp6aa     # CBDC "DvP CBDC EGP" CEGP fee10 dec2 (ICRC-MENA)
export SHARES=275531804196854    ; export SHARES_P=7cutf-fiaad-5jqp2-qh73a   # "ACME Shares" fee0 dec0 (ICRC-MENA)
export LAND=104847466402831      ; export LAND_P=4bymr-2iaab-pvxm7-5sqhq     # "Land Titles" ICRC-7/37
export CORE=ti4fx-siaab-pr7y5-yoxya        ; export CORE_CID=104590569141744  # DvP core (byte-frozen lifecycle)
export XCHG=eit2t-baaab-sl45p-7byca        ; export XCHG_CID=110769186213380  # matching engine (cap 4000, registry-gated)
export LISTING=fzpgo-viaab-ry5kq-2gzca     ; export LISTING_CID=109464390350404 # issuer-listing registry
export CN=coreD                            ; export EN=xchgD                    # manifest canister NAMES for thebes call/query

# ── Demo actor principals (public identifiers) ──
export ISSUER=rfbci-ymk5h-hjswi-ad7ow-hzob4-7j64l-ogux7-7mxv3-4h7r3-ge2ia-pqe   # issuer / share seller
export S1=rfbci-ymk5h-hjswi-ad7ow-hzob4-7j64l-ogux7-7mxv3-4h7r3-ge2ia-pqe
export S2=ejf7v-v4ukt-deqqe-xtllt-nnfno-pkaa7-hqkzo-gaeep-yjjbw-oml4u-fae
export S3=7hvpl-cjfjl-26owi-hq4fv-qnlbq-y5qaa-uxcjf-zo2fg-qgngj-s6woj-qae
export B1=r5pl5-ibbjf-z6rmi-iils5-l4hb2-su6tq-f43lm-qgfqt-hbmr4-6dz7j-yae       # CBDC buyers
export B2=eadba-jh7id-rfxqx-f63cl-ccdfg-xjco2-jscfs-dwawa-3ozjz-coan7-yqe
export B3=deskp-hoe56-ewion-7nuxy-ce4j3-znyaa-skdku-l2uih-joexq-ofoic-yae
export LANDOWNER=apqza-cqj6r-x5pi6-ih3md-ccwdi-wv3di-4s6lr-nmavx-66kkv-hsfvk-xqe # land-title holder
export REGULATOR=x2ju3-rtol6-rwx7h-i4h5r-mbvmy-rofux-kkatd-23cws-h6acd-aim7t-yae # read-only audit observer
export RELAYER=deytp-b76tg-j57r3-u6lga-pimob-va42r-uq44q-mg2zc-iztwc-p5mqd-rae   # venue operator / settlement relayer

export LAND_TOKEN=100   # "Riverside Plot #100", owner = LANDOWNER

acct(){ echo "(record { owner = principal \"$1\"; subaccount = null })"; }

# obligation parser used by the flow scripts
export PAR="${PAR:-$(dirname "${BASH_SOURCE[0]}")/parse_obl.py}"
